{
    "name": "noeles/tdengine-php",
    "version": "1.1.1",
    "description": "TDengine REST 客户端与 ORM 合并包（基于 yurunsoft/tdengine-restful-connector 与 albertwill/tdengine-orm 源码整合，命名空间未变）",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-json": "*",
        "doctrine/annotations": "^1.13",
        "symfony/polyfill-php81": "^1.27",
        "yurunsoft/yurun-http": "^4.3"
    },
    "require-dev": {
        "phpunit/phpunit": ">=7",
        "friendsofphp/php-cs-fixer": "^3.0.2",
        "phpstan/phpstan": "^1.0.2",
        "yurunsoft/ide-helper": "~1.0",
        "swoole/ide-helper": "~4.8"
    },
    "replace": {
        "yurunsoft/tdengine-restful-connector": "self.version",
        "albertwill/tdengine-orm": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Yurun\\TDEngine\\Orm\\": "src/",
            "Yurun\\TDEngine\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "yurunsoft/ide-helper": true
        },
        "sort-packages": true
    },
    "extra": {
        "ide-helper": {
            "list": [
                "tdengine"
            ]
        }
    }
}
